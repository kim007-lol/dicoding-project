{
  "openapi": "3.0.0",
  "info": {
    "title": "KasTumbuh API",
    "version": "1.0.0",
    "description": "API MVP untuk app manajemen keuangan UMKM KasTumbuh."
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "User Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Success", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "User Registration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "business_name": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/api/cash_pools": {
      "get": {
        "summary": "Get all cash pools for standard user",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "post": {
        "summary": "Create a new cash pool",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "is_business": { "type": "boolean" },
                  "initial_balance": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/api/transactions": {
      "get": {
        "summary": "Get transactions with filters",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "from", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "to", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "cash_pool_id", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Paginated transaction list" }
        }
      },
      "post": {
        "summary": "Create new transaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": { "type": "string", "format": "date" },
                  "cash_pool_id": { "type": "integer" },
                  "category": { "type": "string" },
                  "type": { "type": "string", "enum": ["INCOME", "EXPENSE"] },
                  "amount": { "type": "number" },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Transaction created" }
        }
      }
    },
    "/api/transfers": {
      "post": {
        "summary": "Transfer funds between cash pools atomically",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "from_pool_id": { "type": "integer" },
                  "to_pool_id": { "type": "integer" },
                  "amount": { "type": "number" },
                  "date": { "type": "string", "format": "date" },
                  "notes": { "type": "string" },
                  "idempotency_key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Transfer successful" }
        }
      }
    },
    "/api/reports/income-statement": {
      "get": {
        "summary": "SAK EMKM Income Statement Aggregation",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "from", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "to", "in": "query", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_revenue": { "type": "number" },
                    "total_expenses": { "type": "number" },
                    "net_profit": { "type": "number" },
                    "revenue_breakdown": { "type": "array", "items": { "type": "object" } },
                    "expense_breakdown": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "business_name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
